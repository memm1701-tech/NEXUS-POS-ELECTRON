{
  "name": "nexus-pos",
  "version": "1.0.0",
  "description": "Sistema de Facturación Nexus Pos Global",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "keywords": [],
  "author": "Moisés Mariño",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.nexus.pos",
    "productName": "Nexus POS Global",
    "copyright": "Copyright © 2026 Nexus Company C.A",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "assets/logo_nexus_sin_fondo.png",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Nexus POS Global",
      "createDesktopShortcut": true
    },
    "files": [
      "**/*",
      "!data/*",
      "!dist/*"
    ],
    "asar": true,
    "npmRebuild": true
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron/rebuild": "^4.0.3",
    "autoprefixer": "^10.4.22",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.2"
  },
  "dependencies": {
    "@fontsource/roboto": "^5.2.10",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@google/generative-ai": "^0.24.1",
    "@serialport/bindings-cpp": "^13.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "axios": "^1.13.6",
    "baseline-browser-mapping": "^2.8.29",
    "better-sqlite3": "^12.6.2",
    "browserslist": "^4.28.0",
    "caniuse-lite": "^1.0.30001755",
    "chart.js": "^4.5.1",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "electron-to-chromium": "^1.5.255",
    "escalade": "^3.2.0",
    "express": "^5.2.1",
    "ffi-napi": "^4.0.3",
    "firebase": "^12.9.0",
    "fraction.js": "^5.3.4",
    "helmet": "^8.1.0",
    "material-icons": "^1.13.14",
    "nanoid": "^3.3.11",
    "node-releases": "^2.0.27",
    "normalize-range": "^0.1.2",
    "picocolors": "^1.1.1",
    "postcss-value-parser": "^4.2.0",
    "ref-napi": "^3.0.3",
    "serialport": "^13.0.0",
    "source-map-js": "^1.2.1",
    "update-browserslist-db": "^1.1.4",
    "usb": "^2.17.0"
  }
}
